{
  "name": "model-explorer-onnx-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check:converter-sync": "python ../tools/web/sync_web_converter.py --mode check",
    "sync:converter-stamp": "python ../tools/web/sync_web_converter.py --mode update",
    "predev": "npm run check:converter-sync && node ./scripts/copy-visualizer-assets.mjs",
    "dev": "vite",
    "prebuild": "npm run check:converter-sync && node ./scripts/copy-visualizer-assets.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "node ./scripts/copy-visualizer-assets.mjs"
  },
  "dependencies": {
    "ai-edge-model-explorer-visualizer": "^0.1.2",
    "lucide": "^0.525.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vite": "^8.1.2",
    "vite-plugin-pwa": "^1.3.0"
  }
}
